global:
  scrape_interval: 1m
  scrape_timeout: 10s
  evaluation_interval: 1m

scrape_configs:
  - job_name: 'node-exporter-grafana'
    static_configs:
      - targets: ['node-exporter:9100']

  - job_name: 'node-exporter-app'
    static_configs:
      - targets: ['{{ groups["APP"][0] }}:9100']

  - job_name: 'node-exporter-elk'
    static_configs:
      - targets: ['{{ groups["ELK"][0] }}:9100']

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
