apiVersion: v1
kind: ConfigMap
metadata:
  name: vault-config
  namespace: vault
  labels:
    app.kubernetes.io/managed-by: Helm
  annotations:
    meta.helm.sh/release-name: vault
    meta.helm.sh/release-namespace: vault
data:
  vault.hcl: |
    ui = true
    log_level = "trace"
    listener "tcp" {
      tls_disable = 1
      address = "[::]:8200"
      cluster_address = "[::]:8201"
    }
    seal "awskms" {
      region     = "eu-north-1"
      kms_key_id = "{{ kms_key_id }}"
    }
    storage "file" {
      path = "/vault/data"
    }
