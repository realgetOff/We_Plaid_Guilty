version: '3.8'

services:
  app:
    image: "{{ ecr_url }}/{{ repo_name }}:{{ image_tag }}"
    ports:
      - "80:8080"
    environment:
      - "DB_HOST=db"
      - "DB_USER={{ db_user }}"
      - "DB_PASSWORD={{ db_password }}"
      - "DB_NAME={{ db_name }}"
    depends_on:
      - db
    restart: always

  db:
    image: postgres:16-alpine
    environment:
      - POSTGRES_USER={{ db_user }}
      - POSTGRES_PASSWORD={{ db_password }}
      - POSTGRES_DB={{ db_name }}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    restart: always


volumes:
  postgres_data:
