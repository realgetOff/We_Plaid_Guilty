version: '3.8'

services:
  # Backend Go
  app:
    image: "{{ ecr_url }}/{{ repo_name }}:{{ image_tag }}"
    ports:
      - "8080:8080"
    environment:
      - "DB_HOST=db"
      - "DB_PORT=5432"
      - "DB_USER={{ db_user }}"
      - "DB_PASSWORD={{ db_password }}"
      - "DB_NAME={{ db_name }}"
      - "GIN_MODE=release" # Si tu utilises Gin
    depends_on:
      - db
    restart: always

  # Base de données PostgreSQL
  db:
    image: postgres:16-alpine
    environment:
      - POSTGRES_USER={{ db_user }}
      - POSTGRES_PASSWORD={{ db_password }}
      - POSTGRES_DB={{ db_name }}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432" # Pour pouvoir inspecter la DB depuis ton PC (DBeaver/TablePlus)
    restart: always

  # Frontend React (Optionnel si tu le lances via npm start, mais mieux pour le projet)
  frontend:
    build:
      context: ./frontend # Chemin vers ton dossier React
    ports:
      - "5173:5173" # Port par défaut de Vite
    environment:
      - VITE_API_URL=http://localhost:8080
    restart: always

volumes:
  postgres_data:
